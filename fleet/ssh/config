# -----------------------------------------------------------------------------
# U of I / campus clusters — ControlMaster survives Duo 2FA pushes
# Pre-warm: ssh -fN cc-login.campuscluster.illinois.edu
# -----------------------------------------------------------------------------
# >>> uofi-controlmaster BEGIN >>>
# Managed historically by ~/Desktop/UofI-SSH-ControlMaster-Setup-May1-2026/setup.sh
# Purpose: U of Illinois SSH 2FA (Duo Push) survives 1 day+ via ControlMaster
# multiplexing. First SSH to a UofI host triggers Duo; subsequent SSHs to the
# same host within 26h reuse the master socket and skip auth entirely.
Host *.illinois.edu *.uillinois.edu cc-login* linux.ews.illinois.edu linux.cs.illinois.edu delta icc csl-icc csl-icc-girish-compute icrn icrn-dtn
  ControlMaster auto
  ControlPath ~/.ssh/cm/%C
  ControlPersist 26h
  ServerAliveInterval 60
  ServerAliveCountMax 3
  ForwardAgent no
# <<< uofi-controlmaster END <<<

# >>> uofi-aliases BEGIN >>>
# Short aliases. They inherit the ControlMaster wildcard above.
Host icc csl-icc csl-icc-girish-compute
  HostName cc-login.campuscluster.illinois.edu
  User ksa5

Host delta
  HostName login.delta.ncsa.illinois.edu
  User kulbir97
  ServerAliveInterval 60
  ServerAliveCountMax 3
  TCPKeepAlive yes
  ControlMaster auto
  ControlPath ~/.ssh/cm-%r@%h:%p
  ControlPersist 26h
# <<< uofi-aliases END <<<

# ICRN DTN (data transfer node) — inherits ControlMaster from wildcard
# >>> uofi-icrn BEGIN >>>
Host icrn icrn-dtn
  HostName cli-dtn.researchdata.illinois.edu
  User ksa5
# <<< uofi-icrn END <<<

